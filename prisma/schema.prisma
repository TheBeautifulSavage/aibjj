generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  CREATOR
  ADMIN
}

enum Belt {
  WHITE
  BLUE
  PURPLE
  BROWN
  BLACK
}

enum TrainingType {
  GI
  NOGI
  COMP
  DRILLING
  OPEN_MAT
}

enum SubscriptionTier {
  FREE
  PRO
  ANNUAL
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String?          @unique
  emailVerified   DateTime?
  image           String?
  hashedPassword  String?
  role            Role             @default(STUDENT)
  belt            Belt             @default(WHITE)
  stripes         Int              @default(0)
  bodyType        String?
  weight          Float?
  stylePreference String?
  bio             String?          @db.Text
  username        String?          @unique
  customDomain    String?          @unique
  templateId      String?          @default("DARK_PRO")
  academyName     String?
  socialInstagram String?
  socialYoutube   String?
  socialTwitter   String?
  profilePhoto    String?
  academyLogo     String?
  verified        Boolean          @default(false)
  creatorTier     String?          @default("FREE")
  creatorStripeSubscriptionId String? @unique
  subscriptionTier SubscriptionTier @default(FREE)
  isLifetime       Boolean          @default(false)
  stripeCustomerId String?         @unique
  stripeSubscriptionId String?     @unique
  stripeConnectId  String?         @unique
  stripeConnectStatus String?      @default("pending")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  accounts        Account[]
  sessions        Session[]
  journalEntries  JournalEntry[]
  chatMessages    ChatMessage[]
  chatSessions    ChatSession[]
  gamePlans       GamePlan[]
  courses         Course[]
  purchases       Purchase[]
  reviews         Review[]
  blogPosts       BlogPost[]
  blogQueues      BlogQueue[]
  bookmarks       TechniqueBookmark[]
  lessonProgress  LessonProgress[]
  competitions    Competition[]
}

model JournalEntry {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  trainingType   String   @default("GI")
  duration       Int      @default(60)
  partners       String?
  workedOn       String?  @db.Text
  wentWell       String?  @db.Text
  toImprove      String?  @db.Text
  energyLevel    Int?
  rating         Int?
  injuryNotes    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, date])
}

model TechniqueBookmark {
  id          String   @id @default(cuid())
  userId      String
  techniqueId String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([userId, techniqueId])
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("New Chat")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String
  userId        String
  role          String      // "user" or "assistant"
  content       String      @db.Text
  createdAt     DateTime    @default(now())

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GamePlan {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String?  @db.Text
  standingGame    String?  @db.Text
  topGame         String?  @db.Text
  bottomGame      String?  @db.Text
  submissions     String?  @db.Text
  escapes         String?  @db.Text
  gameplanData    String?  @db.Text // JSON string for full AI-generated plan
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Technique {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  position    String   // guard, mount, side-control, back, standing, turtle, half-guard
  category    String   // submission, sweep, pass, escape, takedown, transition
  beltLevel   Belt     @default(WHITE)
  videoUrl    String?
  imageUrl    String?
  steps       String?  @db.Text // JSON array of step strings
  tips        String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([position])
  @@index([category])
  @@index([beltLevel])
}

model Course {
  id          String    @id @default(cuid())
  creatorId   String
  title       String
  slug        String    @unique
  description String?   @db.Text
  price       Float     @default(0)
  coverImage  String?
  published   Boolean   @default(false)
  featured    Boolean   @default(false)
  category    String?
  beltLevel   Belt?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator   User       @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
  purchases Purchase[]
  reviews   Review[]
}

model Lesson {
  id        String   @id @default(cuid())
  courseId   String
  title     String
  description String? @db.Text
  videoUrl  String?
  duration  Int?     // seconds
  order     Int      @default(0)
  free      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress LessonProgress[]
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  courseId     String
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, courseId])
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  courseId   String
  amount    Float
  stripePaymentId String? @unique
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Review {
  id       String   @id @default(cuid())
  userId   String
  courseId  String
  rating   Int      // 1-5
  comment  String?  @db.Text
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model BlogPost {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  slug        String
  content     String   @db.Text
  excerpt     String?  @db.Text
  coverImage  String?
  keywords    String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, slug])
  @@index([userId])
}

model BlogQueue {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topics      String   @db.Text
  frequency   String   @default("daily")
  active      Boolean  @default(true)
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Competition {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  date        DateTime
  location    String?
  division    String?
  weightClass String?
  result      String?  // first, second, third, gold, silver, bronze, did-not-place
  wins        Int      @default(0)
  losses      Int      @default(0)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}
