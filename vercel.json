{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "(?<subdomain>[^.]+)\\.aibjj\\.com"
        }
      ],
      "destination": "/s/:subdomain/:path*"
    }
  ]
}
